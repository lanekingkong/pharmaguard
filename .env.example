# PharmaGuard Environment Configuration
# Copy this file to .env and adjust values

# =================== Neo4j Knowledge Graph ===================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# =================== Model Configuration ===================
MODEL_PATH=./models
DATA_PATH=./data
MODEL_DEVICE=cpu
MODEL_PRECISION=float32

# =================== API Configuration ===================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_TIMEOUT=300
API_MAX_REQUESTS=1000

# =================== Dashboard Configuration ===================
DASHBOARD_PORT=8501
DASHBOARD_THEME=light

# =================== Logging ===================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=./logs/pharmaguard.log

# =================== Security ===================
SECRET_KEY=change-this-to-a-random-secret-key
JWT_EXPIRATION=3600
CORS_ORIGINS=*

# =================== External APIs ===================
DRUGBANK_API_KEY=
PUBCHEM_API_KEY=
OPENFDA_API_KEY=

# =================== Monitoring ===================
ENABLE_METRICS=true
METRICS_PORT=9090
SENTRY_DSN=

# =================== Development ===================
DEBUG=false
PROFILE=false
HOT_RELOAD=false